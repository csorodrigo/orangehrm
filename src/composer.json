        "psr-4": {
            "CiaFerias\\Tests\\": "./test/phpunit",
            "CiaFerias\\Tests\\Admin\\": "./plugins/ciaFeriasAdminPlugin/test",
            "CiaFerias\\Tests\\Authentication\\": "./plugins/ciaFeriasAuthenticationPlugin/test",
            "CiaFerias\\Tests\\Core\\": "./plugins/ciaFeriasCorePlugin/test",
            "CiaFerias\\Tests\\Leave\\": "./plugins/ciaFeriasLeavePlugin/test",
            "CiaFerias\\Tests\\Pim\\": "./plugins/ciaFeriasPimPlugin/test",
            "CiaFerias\\Tests\\OAuth\\": "./plugins/ciaFeriasCoreOAuthPlugin/test",
            "CiaFerias\\Tests\\Time\\": "./plugins/ciaFeriasTimePlugin/test",
            "CiaFerias\\Tests\\Attendance\\": "./plugins/ciaFeriasAttendancePlugin/test",
            "CiaFerias\\Tests\\Maintenance\\": "./plugins/ciaFeriasMaintenancePlugin/test",
            "CiaFerias\\Tests\\I18N\\": "./plugins/ciaFeriasI18NPlugin/test",
            "CiaFerias\\Tests\\Recruitment\\": "./plugins/ciaFeriasRecruitmentPlugin/test",
            "CiaFerias\\Tests\\Performance\\": "./plugins/ciaFeriasPerformancePlugin/test",
            "CiaFerias\\Tests\\CorporateDirectory\\": "./plugins/ciaFeriasCorporateDirectoryPlugin/test",
            "CiaFerias\\Tests\\CorporateBranding\\": "./plugins/ciaFeriasCorporateBrandingPlugin/test",
            "CiaFerias\\Tests\\Dashboard\\": "./plugins/ciaFeriasDashboardPlugin/test",
            "CiaFerias\\Tests\\LDAP\\": "./plugins/ciaFeriasLDAPAuthenticationPlugin/test",
            "CiaFerias\\Tests\\Buzz\\": "./plugins/ciaFeriasBuzzPlugin/test",
            "CiaFerias\\Tests\\Help\\": "./plugins/ciaFeriasHelpPlugin/test",
            "CiaFerias\\Tests\\Mobile\\": "./plugins/ciaFeriasMobilePlugin/test",
            "CiaFerias\\Tests\\Claim\\": "./plugins/ciaFeriasClaimPlugin/test",
            "CiaFerias\\Tests\\OpenidAuthentication\\": "./plugins/ciaFeriasOpenidAuthenticationPlugin/test"
        }
    },
    "scripts": {
        "test": "cd ../ && phpunit",
        "post-autoload-dump": [
            "php ../bin/console orm:generate-proxies",
            "php ../bin/console cache:clear"
        ]
    }
}
