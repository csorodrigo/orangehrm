{
    "name": "cia-ferias/cia-ferias",
    "description": "CIA Férias",
    "keywords": [
        "cia-ferias"
    ],
    "type": "project",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": "^7.4|^8.0",
        "ext-pdo": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-zip": "*",
        "ext-dom": "*",
        "ext-xml": "*",
