            "CiaFerias\\Entity\\": [
                "./plugins/ciaFeriasAdminPlugin/entity",
                "./plugins/ciaFeriasPerformancePlugin/entity",
                "./plugins/ciaFeriasPimPlugin/entity",
                "./plugins/ciaFeriasLeavePlugin/entity",
                "./plugins/ciaFeriasCorePlugin/entity",
                "./plugins/ciaFeriasCoreOAuthPlugin/entity",
                "./plugins/ciaFeriasAuthenticationPlugin/entity",
                "./plugins/ciaFeriasTimePlugin/entity",
                "./plugins/ciaFeriasAttendancePlugin/entity",
                "./plugins/ciaFeriasI18NPlugin/entity",
                "./plugins/ciaFeriasRecruitmentPlugin/entity",
