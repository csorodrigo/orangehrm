            "CiaFerias\\Core\\": "./plugins/ciaFeriasCorePlugin",
            "CiaFerias\\CorporateDirectory\\": "./plugins/ciaFeriasCorporateDirectoryPlugin",
            "CiaFerias\\Dashboard\\": "./plugins/ciaFeriasDashboardPlugin",
            "CiaFerias\\Help\\": "./plugins/ciaFeriasHelpPlugin",
            "CiaFerias\\Leave\\": "./plugins/ciaFeriasLeavePlugin",
