    </testsuite>
    <testsuite name="Pim">
      <directory>src/plugins/ciaFeriasPimPlugin/test</directory>
    </testsuite>
    <testsuite name="OAuth">
      <directory>src/plugins/ciaFeriasCoreOAuthPlugin/test</directory>
    </testsuite>
    <testsuite name="Time">
      <directory>src/plugins/ciaFeriasTimePlugin/test</directory>
    </testsuite>
    <testsuite name="Attendance">
      <directory>src/plugins/ciaFeriasAttendancePlugin/test</directory>
    </testsuite>
